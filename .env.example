# JWT Secret (required)
JWT_SECRET=your-jwt-secret-key-here

# MongoDB
MONGO_URI=mongodb://localhost:27017/actc_website

# Email (optional, for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=ACTC <noreply@actc.org.tw>

# Cron Security (required for production)
CRON_SECRET=your-cron-secret-here
CRON_ALLOWED_IPS=127.0.0.1,::1

# Domain (for certificate verification URL)
DOMAIN=localhost:5001

# Site URL — required in production for CORS allowlist (must match the public-facing origin).
# Example: SITE_URL=https://actc.org.tw
# In development this is not required; localhost origins are allowed automatically.
# SITE_URL=https://actc.org.tw

# Environment
NODE_ENV=development
