# 資料庫設定
MONGO_URI=mongodb://localhost:27017/actc_website

# JWT 設定（生產環境必填；開發未設定時會使用程式內建僅供本機的預設值）
JWT_SECRET=your_strong_random_secret_here

# 伺服器設定
PORT=5001
HOST=0.0.0.0
NODE_ENV=development
# MongoDB 連線逾時（毫秒，Docker 或慢網時可加大）
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# Google Analytics 設定
GA_ENABLED=true
GA_PROPERTY_ID=your_ga_property_id
GA_MEASUREMENT_ID=G-424DY83DBT
GA_KEY_FILE=path/to/your/service-account-key.json

# 檔案上傳設定
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
MAX_FILES=5

# 對外站台網址（驗證信／重設密碼／通知信內連結必須與瀏覽器網址列一致；勿加 :5001）
# 本機開發寄信測試請改：SITE_URL=http://localhost:5001
FRONTEND_URL=https://www.actc-tw.org
SITE_URL=https://www.actc-tw.org

# --- SMTP（驗證信、報告、審核通知）---
# 請複製為 .env 並填入真實密碼；勿將 .env 提交至 Git。
# 寄件帳沿用協會慣用信箱 chmao2008@gmail.com（SMTP_PASSWORD 須為應用程式專用密碼）。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=chmao2008@gmail.com
SMTP_PASSWORD=your_app_password_here
DIGEST_FROM_EMAIL=chmao2008@gmail.com
# 批次 Bcc 時部分 SMTP 要求固定 To，可設為與寄件帳相同
NOTIFY_FALLBACK_TO=chmao2008@gmail.com
# 相容舊變數名（擇一即可）
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=

# 第三方 API 設定
YOUTUBE_API_KEY=your_youtube_api_key
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token