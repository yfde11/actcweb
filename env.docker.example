# 複製為 .env.docker 後供 docker compose 使用：
#   cp env.docker.example .env.docker
#
# 必填：JWT_SECRET
# 會員「信箱驗證／重送驗證／忘記密碼」必須設定完整 SMTP（HOST + USERNAME + PASSWORD），
# 否則 API 仍會建立帳號但不會寄出任何信；啟動日誌會出現 ⚠️ SMTP 未完整設定。
# Gmail 請使用「應用程式專用密碼」，勿用一般登入密碼。

JWT_SECRET=請改為至少32字元的隨機密鑰
# 對外網址（與瀏覽器列一致；經 Caddy 走 80/443，勿寫 :5001）
# 驗證信／重設密碼信內連結皆由此組出；正式站請用 https 與實際網域（勿用內網 IP）。
SITE_URL=https://www.actc-tw.org
# 若主機 80/443 已被占用，可改映射埠（例如 8080:80、8443:443）
HTTP_PORT=80
HTTPS_PORT=443

# --- SMTP（驗證信、報告、審核通知）---
# 以下寄件帳沿用既有協會設定（chmao2008@gmail.com）；SMTP_PASSWORD 請填 Gmail「應用程式專用密碼」。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=chmao2008@gmail.com
SMTP_PASSWORD=your_app_password_here
DIGEST_FROM_EMAIL=chmao2008@gmail.com
NOTIFY_FALLBACK_TO=chmao2008@gmail.com

# --- Resend API（選填）---
# 僅 Render 等封鎖 SMTP port 的環境才需設定；有設定時優先於 SMTP。
# 正式環境使用 Gmail SMTP 時請留空（不要設定此項）。
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
