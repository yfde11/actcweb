# 複製為 .env.docker 後供 docker compose 使用：
#   cp env.docker.example .env.docker
#
# 必填：JWT_SECRET；寄信請填 SMTP_PASSWORD（應用程式專用密碼）

JWT_SECRET=請改為至少32字元的隨機密鑰
WEB_PORT=5001
SITE_URL=http://localhost:5001

# --- SMTP（驗證信、報告、審核通知）---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_smtp_login@gmail.com
SMTP_PASSWORD=your_app_password_here
DIGEST_FROM_EMAIL=your_smtp_login@gmail.com
NOTIFY_FALLBACK_TO=your_smtp_login@gmail.com
