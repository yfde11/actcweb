# 公開站：https://www.actc-tw.org （Let's Encrypt 自動申請／續約）
# 註：根域名 actc-tw.org 若未設定 A／ALIAS，請勿寫進此檔，否則 LE 會因 DNS 驗證失敗。
# ACME 通知信箱（可改為協會信箱）
{
	email actcactc2023@gmail.com
}

www.actc-tw.org {
	encode gzip
	tls /etc/caddy/certs/cloudflare-origin.pem /etc/caddy/certs/cloudflare-origin.key
	reverse_proxy web:5001
}
